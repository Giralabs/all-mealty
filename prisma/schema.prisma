generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  price          Decimal     @db.Decimal(10, 2)
  imageUrl       String      @map("image_url")
  supermarket    supermarket
  isFood         Boolean     @map("is_food")
  dietTypes      String[]    @default([]) @map("diet_types")
  allergens      String[]    @default([]) @map("allergens")
  cookingMethods String[]    @default([]) @map("cooking_methods")
  nutritionalInfo Json?      @map("nutritional_info")
  lastUpdated    DateTime    @default(now()) @updatedAt @map("last_updated") @db.Timestamptz(6)

  @@index([supermarket])
  @@map("mealty_products")
}

model ScrapingQueue {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supermarket  supermarket
  categoryUrl  String       @map("category_url")
  categoryName String       @map("category_name")
  status       queue_status @default(pending)
  lastAttempt  DateTime?    @map("last_attempt") @db.Timestamptz(6)
  error        String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, supermarket], map: "mealty_queue_status_supermarket_idx")
  @@map("mealty_scraping_queue")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model mealty_user_profiles {
  id            String   @id @db.Uuid
  created_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  supermarket   String
  weekly_budget Decimal  @db.Decimal
  dietary_goals String[]
  allergies     String[]
  appliances    String[]
}

enum queue_status {
  pending
  processing
  completed
  failed
}

enum supermarket {
  mercadona
  aldi
  dia
  carrefour
  alcampo
  lidl
}
